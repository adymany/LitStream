# Environment Variables

# CDN Base URL for video files
# Leave empty for local development (uses /videos/ folder)
# For production with Backblaze B2:
# VITE_CDN_BASE_URL=https://f003.backblazeb2.com/file/your-bucket-name

VITE_CDN_BASE_URL=

# B2 Download Authorization Token (for private bucket access)
# Generate via B2 API: b2_get_download_authorization
# Token expires after 7 days - regenerate and update this value
VITE_B2_AUTH_TOKEN=
